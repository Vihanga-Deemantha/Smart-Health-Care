      "name": "Authentication",
      "item": [
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dr.smith@hospital.com\",\n  \"password\": \"SecurePassword123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"role\": \"DOCTOR\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/doctor",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", "doctor"]
            }
          },
          "response": []
        },
        {
          "name": "Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    var token = jsonData.data.accessToken || jsonData.accessToken || jsonData.token;",
                  "    var userId = jsonData.data.user.id || jsonData.data.user.userId || jsonData.data.userId;",
                  "    if (token && userId) {",
                  "        pm.environment.set('doctor_token', token);",
                  "        pm.environment.set('doctor_user_id', userId);",
                  "        pm.collectionVariables.set('doctor_token', token);",
                  "        pm.collectionVariables.set('doctor_user_id', userId);",
                  "        pm.test('Login successful - Token stored', function() {",
                  "            pm.expect(token).to.exist;",
                  "            pm.expect(userId).to.exist;",
                  "        });",
                  "    } else {",
                  "        pm.test('Token or ID not found in response', function() {",
                  "            pm.expect.fail('accessToken or user ID missing in response');",
                  "        });",
                  "    }",
                  "} else {",
                  "    pm.test('Login failed', function() {",
                  "        pm.expect.fail('Auth request failed with status ' + pm.response.code);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctor_email}}\",\n  \"password\": \"{{doctor_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Doctor Profile Management",
      "item": [
        {
          "name": "Get All Doctors",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Response has doctors array', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.doctors).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Resolve doctor_id from doctor_user_id when possible', function() {",
                  "    var jsonData = pm.response.json();",
                  "    var doctors = (jsonData.data && jsonData.data.doctors) || [];",
                  "    var doctorUserId = pm.collectionVariables.get('doctor_user_id') || pm.environment.get('doctor_user_id');",
                  "    if (!doctorUserId) {",
                  "        return;",
                  "    }",
                  "",
                  "    var match = doctors.find(function(d) {",
                  "        return String(d.userId) === String(doctorUserId);",
                  "    });",
                  "",
                  "    if (match && match._id) {",
                  "        pm.collectionVariables.set('doctor_id', match._id);",
                  "        pm.environment.set('doctor_id', match._id);",
                  "    }",
                  "});",
                  "",
                  "pm.test('Doctor fields are correct', function() {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.doctors.length > 0) {",
                  "        var doctor = jsonData.data.doctors[0];",
                  "        pm.expect(doctor).to.have.property('_id');",
                  "        pm.expect(doctor).to.have.property('licenseNumber');",
                  "        pm.expect(doctor).to.have.property('specialties');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{doctor_service_url}}/api/doctors",
              "host": ["{{doctor_service_url}}"],
              "path": ["api", "doctors"]
            }
