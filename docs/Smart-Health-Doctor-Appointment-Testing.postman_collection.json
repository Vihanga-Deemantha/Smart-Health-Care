    {
      "name": "Doctor: Verify Appointments",
      "item": [
        {
          "name": "Get All Doctor Appointments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctor_token}}" }
            ],
            "url": "{{BASE_APPT}}/api/appointments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const data = res.data || res;",
                  "const items = data.items || data.appointments || data;",
                  "const list = Array.isArray(items) ? items : (items.items || []);",
                  "pm.test(\"Got appointments\", () => pm.response.to.have.status(200));",
                  "const booked = list.filter((item) => item.status === \"BOOKED\");",
                  "const confirmed = list.filter((item) => item.status === \"CONFIRMED\");",
                  "console.log(\"BOOKED (Pending):\", booked.length);",
                  "console.log(\"CONFIRMED (Schedule):\", confirmed.length);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Pending Only",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctor_token}}" }
            ],
            "url": "{{BASE_APPT}}/api/appointments?status=BOOKED"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
