      "item": [
        {
          "name": "Get Doctor Availability",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctor_token}}" }
            ],
            "url": "{{BASE_DOCTOR}}/api/availability/{{doctor_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const availability = (res.data && res.data.availability) || res.availability || res.data || {};",
                  "pm.test(\"Got availability\", () => pm.response.to.have.status(200));",
                  "console.log(\"Weekly Schedule:\", JSON.stringify(availability.weeklySchedule || [], null, 2));",
                  "console.log(\"Off Days:\", availability.offDays);",
                  "console.log(\"Blocked Dates:\", availability.blockedDates);"
                ]
              }
            }
          ]
        },
        {
          "name": "Set Doctor Availability",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctor_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"weeklySchedule\": [\n    {\n      \"weekday\": \"Thursday\",\n      \"startTime\": \"09:00\",\n      \"endTime\": \"17:00\",\n      \"duration\": 30,\n      \"mode\": \"TELEMEDICINE\",\n      \"isActive\": true\n    },\n    {\n      \"weekday\": \"Friday\",\n      \"startTime\": \"10:00\",\n      \"endTime\": \"16:00\",\n      \"duration\": 30,\n      \"mode\": \"IN_PERSON\",\n      \"isActive\": true\n    }\n  ],\n  \"offDays\": [\"Saturday\", \"Sunday\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{BASE_DOCTOR}}/api/availability/{{doctor_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Availability saved\", () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
