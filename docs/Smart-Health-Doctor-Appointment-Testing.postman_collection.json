  "item": [
    {
      "name": "Auth: Get Tokens",
      "item": [
        {
          "name": "Login as Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patient_email}}\",\n  \"password\": \"{{patient_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{BASE_AUTH}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const data = res.data || res;",
                  "const token = res.token || res.accessToken || data.accessToken || \"\";",
                  "const user = res.user || data.user || (data.data ? data.data.user : null);",
                  "const setVar = (key, value) => { pm.environment.set(key, value); pm.collectionVariables.set(key, value); };",
                  "setVar(\"patient_token\", token || \"\");",
                  "setVar(\"patient_id\", (user && (user.id || user._id)) || res.userId || \"\");",
                  "pm.test(\"Patient login success\", () => pm.response.to.have.status(200));",
                  "console.log(\"Patient ID:\", pm.collectionVariables.get(\"patient_id\") || pm.environment.get(\"patient_id\"));",
                  "console.log(\"Patient Token:\", pm.collectionVariables.get(\"patient_token\") || pm.environment.get(\"patient_token\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Doctor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctor_email}}\",\n  \"password\": \"{{doctor_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{BASE_AUTH}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const data = res.data || res;",
                  "const token = res.token || res.accessToken || data.accessToken || \"\";",
                  "const user = res.user || data.user || (data.data ? data.data.user : null);",
                  "const setVar = (key, value) => { pm.environment.set(key, value); pm.collectionVariables.set(key, value); };",
                  "setVar(\"doctor_token\", token || \"\");",
                  "setVar(\"doctor_user_id\", (user && (user.id || user._id)) || res.userId || \"\");",
                  "pm.test(\"Doctor login success\", () => pm.response.to.have.status(200));",
                  "console.log(\"Doctor User ID:\", pm.collectionVariables.get(\"doctor_user_id\") || pm.environment.get(\"doctor_user_id\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Doctor Profile (resolve doctor_id)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctor_token}}" }
            ],
            "url": "{{BASE_DOCTOR}}/api/doctors"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const data = res.data || res;",
                  "const doctors = data.doctors || data.items || data;",
                  "const getVar = (key) => pm.environment.get(key) || pm.collectionVariables.get(key);",
                  "const setVar = (key, value) => { pm.environment.set(key, value); pm.collectionVariables.set(key, value); };",
                  "const doctorUserId = getVar(\"doctor_user_id\");",
                  "let doctor = null;",
                  "if (Array.isArray(doctors)) {",
                  "  doctor = doctors.find((item) => String(item.userId) === String(doctorUserId));",
                  "  if (!doctor && doctors.length) { doctor = doctors[0]; }",
                  "} else if (data.doctor) {",
                  "  doctor = data.doctor;",
                  "}",
                  "const doctorId = (doctor && (doctor._id || doctor.id)) || doctorUserId || \"\";",
                  "setVar(\"doctor_id\", doctorId);",
                  "pm.test(\"Got doctor profile\", () => pm.response.to.have.status(200));",
                  "console.log(\"Doctor Profile ID:\", doctorId);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
