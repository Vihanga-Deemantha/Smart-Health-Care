                  "const list = Array.isArray(items) ? items : (items.items || []);",
                  "pm.test(\"Got pending\", () => pm.response.to.have.status(200));",
                  "console.log(\"Pending count:\", list.length);"
                ]
              }
            }
          ]
        },
        {
          "name": "Accept an Appointment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctor_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\",\n  \"action\": \"ACCEPT\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{BASE_APPT}}/api/appointments/{{appointment_id}}/respond"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Appointment accepted\", () => pm.response.to.have.status(200));",
                  "console.log(\"Appointment is now CONFIRMED\");"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject an Appointment",
          "request": {
            "method": "PATCH",
            "header": [
